{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CorsSettings": {
    "AllowedOrigins": "https://localhost:5173;https://nimblist.tmnrtn.com"
  },
  "FrontendAppSettings": {
    "BaseUrl": "https://localhost:5173" // Use HTTPS version!
    // For production, use: "https://nimblist.yourdomain.com"
  },
  "ClassificationService": {
    "PredictUrl": "http://nimblist.classification:5000/predict"
  },
  "RecipeScraperService": {
    "ScrapeUrl": "http://nimblist.recipescraper:5001/scrape",
    "ScrapeImageUrl": "http://nimblist.recipescraper:5001/scrape-image",
    "ParseUrl": "http://nimblist.recipescraper:5001/parse-ingredients"
  },
  // VAPID keys are required for Web Push notifications.
  // Generate with: npx web-push generate-vapid-keys
  // Set in appsettings.Development.json (gitignored) for local dev,
  // or via VapidSettings__PublicKey / VapidSettings__PrivateKey env vars in production.
  "VapidSettings": {
    "Subject": "mailto:your@email.com",
    "PublicKey": "",
    "PrivateKey": ""
  },
  "PayPal": {
    "Mode": "sandbox",
    "ClientId": "",
    "ClientSecret": "",
    "PlanId": "",
    "WebhookId": ""
  },
  "Resend": {
    "ApiKey": "",
    "FromAddress": "Nimblist <noreply@nimblist.app>"
  },
  "RateLimits": {
    "AuthIp":              { "PermitLimit": 10, "WindowMinutes": 5  },
    "RecipeImport":        { "PermitLimit": 10, "WindowMinutes": 60 },
    "ImageImport":         { "PermitLimit": 5,  "WindowMinutes": 60 },
    "ImageSearch":         { "PermitLimit": 30, "WindowMinutes": 60 },
    "SubscriptionActivate":{ "PermitLimit": 5,  "WindowMinutes": 60 }
  }
}