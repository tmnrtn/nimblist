# Caddyfile.staging — plain HTTP, TLS terminated externally by NPM
# X-Forwarded-Proto is hardcoded to https since staging is always HTTPS via NPM.

:80 {
    @backend path /api/* /hubs/* /Identity/* /signin-*

    handle @backend {
        reverse_proxy nimblist-api:8080 {
            header_up X-Forwarded-Proto https
        }
    }

    handle {
        reverse_proxy nimblist-frontend:80
    }
}
