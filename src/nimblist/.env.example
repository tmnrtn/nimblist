# =============================================================================
# Nimblist — environment variable reference
# Copy this file to .env and fill in the values before running docker compose.
# Used by: docker-compose.prod.yml
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=nimblistdb
POSTGRES_USER=nimblistuser
POSTGRES_PASSWORD=changeme_strong_password

# Full connection string (references the vars above — keep in sync)
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis_cache
ConnectionStrings__Redis=${REDIS_HOST}:6379

# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------
# Production frontend origin — used for OAuth redirect and email links
FRONTEND_BASE_URL=https://nimblist.example.com

# CORS — semicolon-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://nimblist.example.com

# -----------------------------------------------------------------------------
# OAuth providers (only configure the ones you want to enable)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Admin
# -----------------------------------------------------------------------------
# User with this email will be promoted to the Admin role on startup
ADMIN_EMAIL=you@example.com

# -----------------------------------------------------------------------------
# Web Push (VAPID)
# Generate a new key pair for production:
#   npx web-push generate-vapid-keys
# Never reuse development keys in production.
# -----------------------------------------------------------------------------
VAPID_SUBJECT=mailto:you@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# PayPal subscription billing
# Use Mode=sandbox for testing, Mode=live for production.
# -----------------------------------------------------------------------------
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_PLAN_ID=
PAYPAL_WEBHOOK_ID=

# -----------------------------------------------------------------------------
# Email — Resend (https://resend.com)
# Create an account, verify your domain, and generate an API key.
# FromAddress format: "Name <address@yourdomain.com>"
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_ADDRESS=Nimblist <noreply@nimblist.example.com>

# -----------------------------------------------------------------------------
# Recipe scraper LLM (optional — enables URL import fallback and image import)
# Supported providers: openrouter, openai, anthropic, gemini, ollama
# Leave LLM_PROVIDER empty to disable all LLM features.
# -----------------------------------------------------------------------------
RECIPESCRAPER_LLM_PROVIDER=openrouter
RECIPESCRAPER_LLM_MODEL=anthropic/claude-haiku-4-5
RECIPESCRAPER_LLM_VISION_MODEL=anthropic/claude-haiku-4-5
OPENROUTER_API_KEY=sk-or-v1-
# Only needed when using ollama provider:
OLLAMA_BASE_URL=

# -----------------------------------------------------------------------------
# Webhook (CI/CD auto-deploy trigger)
# Generate a strong random secret: openssl rand -hex 32
# -----------------------------------------------------------------------------
WEBHOOK_SECRET=changeme_strong_secret
COMPOSE_PROJECT_NAME=nimblist

# -----------------------------------------------------------------------------
# Rate limits (optional — these override the defaults in appsettings.json)
# Units: PermitLimit = number of requests, WindowMinutes = rolling window
# -----------------------------------------------------------------------------
# RATE_AUTH_IP_LIMIT=10
# RATE_AUTH_IP_WINDOW=5
# RATE_RECIPE_IMPORT_LIMIT=10
# RATE_RECIPE_IMPORT_WINDOW=60
# RATE_IMAGE_IMPORT_LIMIT=5
# RATE_IMAGE_IMPORT_WINDOW=60
# RATE_IMAGE_SEARCH_LIMIT=30
# RATE_IMAGE_SEARCH_WINDOW=60
# RATE_SUB_ACTIVATE_LIMIT=5
# RATE_SUB_ACTIVATE_WINDOW=60
